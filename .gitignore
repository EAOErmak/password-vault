# JavaScript / TypeScript dependencies and frontend build output
node_modules/
dist/
dist-ssr/
*.local

# Rust / Cargo / Tauri build output
/target/
src-tauri/target/*
!src-tauri/target/release/
src-tauri/target/release/*
!src-tauri/target/release/bundle/

# Tauri generated bundles, installers, and packaged apps
# (We allow them in the bundle folder above)
*.msi
*-setup.exe
*.app
*.dmg
*.AppImage
*.deb
*.rpm
!src-tauri/target/release/bundle/**/*.msi
!src-tauri/target/release/bundle/**/*-setup.exe

# Local vault databases, SQLCipher files, and user data
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm
local-data/
vaults/
backups/

# Environment files and local secrets
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx

# Logs, caches, and temporary files
*.log
logs/
tmp/
temp/
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# Editor and IDE files
.idea/
.vscode/
*.swp
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Keep important lock/config/source files tracked
# Do not ignore:
# - package.json
# - pnpm-lock.yaml
# - Cargo.toml
# - Cargo.lock
# - tauri.conf.json
# - application source files
